{"name":"Diplomat","type":"traveller","img":"systems/twodsix/assets/icons/default_actor.png","system":{"name":"","homeWorld":"","nationality":"","species":"","age":{"value":"18","min":0},"hits":{"value":18,"min":0,"max":18,"lastDelta":0},"gender":"","radiationDose":{"value":0,"max":0,"min":0},"encumbrance":{"value":0,"max":0},"primaryArmor":{"value":"6"},"secondaryArmor":{"value":"0"},"heroPoints":2,"radiationProtection":{"value":"0"},"contacts":"","allies":"","enemies":"","untrainedSkill":"lN6fgWwhghX2Jvnc","description":"","bio":"","notes":"","finances":{"cash":"0","pension":"0","debt":"0","payments":"0","livingCosts":"0","financial-notes":""},"characteristics":{"strength":{"key":"strength","value":6,"damage":0,"label":"Strength","shortLabel":"STR","displayShortLabel":""},"dexterity":{"key":"dexterity","value":7,"damage":0,"label":"Dexterity","shortLabel":"DEX","displayShortLabel":""},"endurance":{"key":"endurance","value":6,"damage":0,"label":"Endurance","shortLabel":"END","displayShortLabel":""},"intelligence":{"key":"intelligence","value":10,"damage":0,"label":"Intelligence","shortLabel":"INT","displayShortLabel":""},"education":{"key":"education","value":13,"damage":0,"label":"Education","shortLabel":"EDU","displayShortLabel":""},"socialStanding":{"key":"socialStanding","value":14,"damage":0,"label":"Social Standing","shortLabel":"SOC","displayShortLabel":""},"psionicStrength":{"key":"psionicStrength","value":7,"damage":0,"label":"Psionic Strength","shortLabel":"PSI","displayShortLabel":""},"stamina":{"key":"stamina","value":6,"damage":0,"label":"Stamina","shortLabel":"STA","displayShortLabel":""},"lifeblood":{"key":"lifeblood","value":12,"damage":0,"label":"Lifeblood","shortLabel":"LFB","displayShortLabel":""},"alternative1":{"key":"alternative1","value":7,"damage":0,"label":"Alternative 1","shortLabel":"ALT1","displayShortLabel":""},"alternative2":{"key":"alternative2","value":7,"damage":0,"label":"Alternative 2","shortLabel":"ALT2","displayShortLabel":""}},"conditions":{"woundedEffect":0,"encumberedEffect":0},"characteristicEdit":false,"movement":{"burrow":0,"climb":0,"fly":0,"swim":0,"walk":0,"units":"ft","hover":false},"hideStoredItems":{"weapon":false,"armor":false,"augment":false,"equipment":false,"consumable":false,"attachment":false},"experience":{"value":0,"totalEarned":0},"xpNotes":""},"items":[{"_id":"lN6fgWwhghX2Jvnc","name":"Untrained","type":"skills","img":"icons/svg/item-bag.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":-3,"characteristic":"NONE","type":"skills","description":"","shortdescr":"","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"twodsix":{"untrainedSkill":true}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"JpkZYSW54EqcSX3K","name":"Admin","type":"skills","img":"./systems/twodsix/assets/icons/admin.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"EDU","type":"skills","description":"Administration: understanding and dealing with bureaucracies, businesses, and the law. Also covers forgery.<br><br>Examples: throw Admin/EDU 10+ to deal with a complex government bureaucracy and get permits. Throw Admin/INT opposed by Investigate/INT to pass off forged documents as authentic. Throw Admin/INT or Admin/SOC 10+ to bluff your way past a routine customs inspection.","shortdescr":"understanding and dealing with bureaucracies, businesses, and the law","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.YS1V8gReRrBqKIiu"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"Rr0SzLbfWedkuSiE","name":"Liaison","type":"skills","img":"./systems/twodsix/assets/icons/liaison.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":3,"characteristic":"SOC","type":"skills","description":"Liaison: negotiation and diplomacy in a myriad of social situations. This skill covers diplomatic meetings, haggling in interstellar trading negotiations, or at the shouq, and talking down a gunman who is holding hostages.<br><br>Examples: throw Liaison/SOC 8+ to strike a deal with a reluctant alien merchant. Throw Liaison/INT 8+ to read a room and negotiate with the person who really makes the decisions. Throw Liaison/EDU 10+ to understand proper etiquette when dealing with an honor-based culture. Throw Liaison/INT opposed by Liaison/INT to haggle over a price.","shortdescr":"Negotiation and diplomacy in a myriad of social situations","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.WGIiT2CCuzxPJd1x"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"hK7D8KbMmovVU2bK","name":"Deception","type":"skills","img":"./systems/twodsix/assets/icons/deception.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"SOC","type":"skills","description":"Deception: convincingly avoiding the truth and misleading other people. This skill covers sleight-of-hand and disguise as well.<br><br>Examples: throw Deception/SOC 10+ to lie your way past a corporate sentry while posing as a visiting executive. Throw Deception/INT opposed by Investigation/INT to lie during a police interrogation and not be found out. Throw Deception/END 12+ to fool a polygraph lie detector test. Throw Deception/DEX 10+ to palm a small item (can be opposed by Recon or Investigation).","shortdescr":"Convincingly avoiding the truth and misleading other people","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.iQIhVdEsFHhdELN0"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rXFxhrcTqeCVvl81","name":"Carousing","type":"skills","img":"./systems/twodsix/assets/icons/carousing.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"SOC","type":"skills","description":"Carousing: the art of mingling in social settings to achieve your goals. Also covers gambling.<br><br>Examples: throw Carousing/SOC 6+ to gather useful rumors at a party. Throw opposed Carousing/END to drink someone under the table.","shortdescr":"The art of mingling in social settings to achieve your goals","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.Ivc9wU3L8mFObSBW"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"3Gn7O37BgetYt7gu","name":"Investigation","type":"skills","img":"./systems/twodsix/assets/icons/investigate.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"INT","type":"skills","description":"Investigation: keen observation, forensics, research, and detailed analysis.<br><br>>Examples: throw Investigation/INT 6+ to locate and extract fingerprints from a crime scene. Throw Investigation/EDU 10+ (or opposed by someone’s Admin/EDU) to uncover evidence of fraud or other irregularities in a business’ accounting practices. Throw Investigation/INT 10+ to find hidden levers, or to notice that a crime scene was disturbed before being discovered. Throw Investigation/INT 8+ to perform surveillance on a target.","shortdescr":"This skill combines keen observation, forensics, research, and detailed analysis","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.isLeYQ7qxqaouJOW"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rimGXVgafwQ5Pgbr","name":"Computers","type":"skills","img":"./systems/twodsix/assets/icons/computers.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"EDU","type":"skills","description":"Computer: programming, working with computer hardware, and hacking. This skill also covers the use of sensors and communications gear.<br><br>Examples: throw Computer/EDU 8+ to purge malware from a computer. Throw Computer/EDU 12+ to hack a government server and download a database. Throw Opposed Computer/EDU to avoid detection and tracing while doing so.","shortdescr":"Programming, working with and hacking computer hardware; comms and sensors operation","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.3dz34XdGUGhAu0wc"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"PqvhXmRqVP9XpIgh","name":"Stealth Pistol","type":"weapon","img":"./systems/twodsix/assets/icons/body-pistol.svg","system":{"name":"Body Pistol","techLevel":8,"description":"This is an especially light, discreet, and concealable weapon made from advanced polymers. A concealed body pistol can also be disguised as a number of more innocuous items, like comms, digital recorders, and so on.<br><br>Double Tap: may fire 2 bullets in one attack to gain DM+1 to damage.","shortdescr":"Body Pistol - ranged","quantity":1,"weight":1,"price":500,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"Gun Combat","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"5/20","damage":"2d6","damageBonus":0,"magazineSize":0,"ammo":"6","useConsumableForAttack":"","magazineCost":20,"type":"weapon","location":"","lawLevel":"1","rangeBand":"5/20","weaponType":"ranged","damageType":"P - Double tap","rateOfFire":"1","recoil":true,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_sk461konhrd","path":"Cepheus Deluxe - Items#/CF_SEP/Weapons#/CF_SEP/Ranged Weapons","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.nGvTh4NNnhelRaRy"}},"_stats":{"systemId":null,"systemVersion":