{"name":"Elite Bodyguard","type":"traveller","img":"systems/twodsix/assets/icons/default_actor.png","system":{"name":"","homeWorld":"","nationality":"","species":"","age":{"value":"","min":0},"hits":{"value":19,"min":0,"max":29,"lastDelta":17},"gender":"","radiationDose":{"value":0,"max":0,"min":0},"encumbrance":{"value":0,"max":0},"primaryArmor":{"value":"8"},"secondaryArmor":{"value":"0"},"heroPoints":2,"radiationProtection":{"value":"0"},"contacts":"","allies":"","enemies":"","untrainedSkill":"pyDEKKXipO2fX7A7","description":"","bio":"","notes":"","finances":{"cash":"0","pension":"0","debt":"0","payments":"0","livingCosts":"0","financial-notes":""},"characteristics":{"strength":{"key":"strength","value":10,"damage":10,"label":"Strength","shortLabel":"STR","displayShortLabel":""},"dexterity":{"key":"dexterity","value":9,"damage":0,"label":"Dexterity","shortLabel":"DEX","displayShortLabel":""},"endurance":{"key":"endurance","value":10,"damage":0,"label":"Endurance","shortLabel":"END","displayShortLabel":""},"intelligence":{"key":"intelligence","value":7,"damage":0,"label":"Intelligence","shortLabel":"INT","displayShortLabel":""},"education":{"key":"education","value":7,"damage":0,"label":"Education","shortLabel":"EDU","displayShortLabel":""},"socialStanding":{"key":"socialStanding","value":7,"damage":0,"label":"Social Standing","shortLabel":"SOC","displayShortLabel":""},"psionicStrength":{"key":"psionicStrength","value":7,"damage":0,"label":"Psionic Strength","shortLabel":"PSI","displayShortLabel":""},"stamina":{"key":"stamina","value":12,"damage":0,"label":"Stamina","shortLabel":"STA","displayShortLabel":""},"lifeblood":{"key":"lifeblood","value":24,"damage":0,"label":"Lifeblood","shortLabel":"LFB","displayShortLabel":""},"alternative1":{"key":"alternative1","value":7,"damage":0,"label":"Alternative 1","shortLabel":"ALT1","displayShortLabel":""},"alternative2":{"key":"alternative2","value":7,"damage":0,"label":"Alternative 2","shortLabel":"ALT2","displayShortLabel":""}},"conditions":{"woundedEffect":0,"encumberedEffect":0},"characteristicEdit":false,"movement":{"burrow":0,"climb":0,"fly":0,"swim":0,"walk":0,"units":"ft","hover":false},"hideStoredItems":{"weapon":false,"armor":false,"augment":false,"equipment":false,"consumable":false,"attachment":false},"experience":{"value":0,"totalEarned":0},"xpNotes":""},"items":[{"_id":"pyDEKKXipO2fX7A7","name":"Untrained","type":"skills","img":"icons/svg/item-bag.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":-3,"characteristic":"NONE","type":"skills","description":"","shortdescr":"","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"twodsix":{"untrainedSkill":true}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"bCdaqVG6HcFZhcSA","name":"Gun Combat","type":"skills","img":"./systems/twodsix/assets/icons/gun-combat.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":3,"characteristic":"DEX","type":"skills","description":"Gun Combat: using small arms, crossbows, and bows in combat.<br><br>Examples: throw Gun Combat/DEX 8+ to hit a target in Effective range with a handgun. Throw Gun combat/DEX 10+ to hit a target at Maximum range. See the Combat chapter for more information.","shortdescr":"Using small arms, crossbows, and bows in combat","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.enQOAVdQXndSdf0j"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"OKllPyuzWOGNPfLx","name":"Melee Combat","type":"skills","img":"./systems/twodsix/assets/icons/melee.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":3,"characteristic":"STR","type":"skills","description":"Melee Combat: fighting hand-to-hand, either with a weapon or unarmed.<br><br>Examples: throw Melee Combat/STR 8+ to hit a target with a sword. The Combat chapter has more detailed examples of how to use the Melee Combat skill.","shortdescr":"Fighting hand-to-hand, either with a weapon or unarmed","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.eVVFG5oHgsBycy1K"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"VjcUZ6smeBW97B1u","name":"Athletics","type":"skills","img":"./systems/twodsix/assets/icons/athletics-dexterity.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"END","type":"skills","description":"Athletics: the ability to exert oneself physically. You may add the Athletics skill to appropriate physical characteristic rolls. This skill is never rolled unskilled.<br><br>Examples: throw Athletics/END 6+ to swim against a powerful current. To move past obstacles while running, using Parkour-style moves, throw Athletics/DEX 8+. To climb a rope quickly, throw Athletics/STR 8+.","shortdescr":"The ability to exert oneself physically","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.bupjJOC81mWCqwd4"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"v0mXl7kfPCwl4ihq","name":"Recon","type":"skills","img":"./systems/twodsix/assets/icons/recon.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"INT","type":"skills","description":"Recon: scouting for danger and spotting threats, including traps. Recon also covers performing forward observation for artillery.<br><br>Examples: throw Recon/INT 8+ to correctly identify the composition of a concealed enemy force. Throw Recon/INT 10+ to identify a likely ambush kill zone. Throw Recon/INT 10+ to call down an airstrike on a large stationary target, such as a building. Throw Recon/INT 8+ to track a target in the wilderness. Throw Recon/INT 12+ to locate a devilishly hidden trap.","shortdescr":"Scouting for danger and spotting threats, including traps","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.hKNf0aBpr4jX4I1w"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"Otl7gtXdhN23mf9K","name":"Gauss Pistol","type":"weapon","img":"./systems/twodsix/assets/icons/gauss-pistol.svg","system":{"name":"Gauss Rifle","techLevel":12,"description":"These weapons accelerate small metal spikes to supersonic velocities. Though the principles behind their function have been understood since the early industrial age, Gauss weapons are typically beyond the manufacturing capabilities of frontier worlds. They do appear, from time to time, in the hands of well-equipped mercenary forces.<br><br>Auto 2: These weapons fire multiple rounds with every pull of the trigger, filling the air with a hail of fire. A weapon with the Auto aspect can make attacks in three fire modes: single, burst, and full auto, as described in the Combat chapter.","shortdescr":"Gauss Pistol - ranged","quantity":1,"weight":1,"price":1000,"traits":[],"consumables":[],"skillModifier":0,"skill":"bCdaqVG6HcFZhcSA","associatedSkillName":"Gun Combat","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"20/100","damage":"3d6","damageBonus":0,"magazineSize":0,"ammo":"30","useConsumableForAttack":"","magazineCost":30,"type":"weapon","location":"","lawLevel":"6","rangeBand":"20/100","weaponType":"ranged","damageType":"P - AV 1D, Auto 2","rateOfFire":"2","recoil":false,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_sk461konhrd","path":"Cepheus Deluxe - Items#/CF_SEP/Weapons#/CF_SEP/Ranged Weapons","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.796fjj1h1cJWoI9L"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"CSj0Wzy3FeT2wHnB","name":"Heavy Ballistic Cloth","type":"armor","img":"./systems/twodsix/assets/icons/cloth.svg","system":{"name":"","techLevel":7,"description":"A modern heavy-duty ballistic- cloth armor. Commonly worn by soldiers, well-equipped security, and TL7 mercenaries. Counts as two Items for encumbrance purposes and is not concealable.","shortdescr":"modern heavy-duty ballistic-cloth armor","quantity":1,"weight":2,"price":250,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"armor":6,"secondaryArmor":{"value":0},"radiationProtection":{"value":0},"type":"armor","useConsumableForAttack":"","location":["inventory","storage"],"isPowered":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"exportSource":{"world":"on_the_run","system":"twodsix","coreVersion":"0.6.6","systemVersion":"0.6.27"},"cf":{"id":"temp_3odrbwitf0c","path":"Cepheus Deluxe - Items#/CF_SEP/Armor","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.EKKJ33cnnnmKvcHo"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ZQ60TQh22In5eLgN","name":"Medkit","type":"equipment","img":"systems/twodsix/assets/icons/medkit.svg","system":{"name":"","techLevel":8,"description":"","shortdescr":"Medkit","quantity":1,"weight":1,"price":100,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"Medicine","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_bpg3uct3zcp","path":"Cepheus Deluxe - Items#/CF_SEP/Equipment","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.JlAnmUJ4vsv6RfjC"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"JsYaCTyOevH9Wczo","name":"Omnicomm","type":"equipment","img":"systems/twodsix/assets/icons/omnicomm.svg","system":{"name":"","techLevel":8,"description":"Today’s smartphones will eventually evolve into an Omnicomm, a combination of all your telecom needs in one place, with holographic augmented reality capability. Designed to integrate with whatever telecommunications networks are present on a given world. TL8 batteries for these devices last for a few days; TL9 batteries last for months between recharging.","shortdescr":"smart communicator","quantity":1,"weight":1,"price":50,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"Computers","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_bpg3uct3zcp","path":"Cepheus Deluxe - Items#/CF_SEP/Equipment","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.MlLa4SgNWAZAdwQk"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"3A2KhScjhlNfxb6q","name":"Subdermal Armor","type":"augment","img":"./systems/twodsix/assets/icons/subdermal-armor.svg","system":{"name":"","techLevel":9,"description":"Keratin and ceramic bone lacing and light shielding of vital organs provides 2 points of armor protection. The implant is subtle enough to pass visual inspection but can be spotted with sensor scans. Subdermal armor is added to the protection rating of any worn armor. Subdermal armor is legal on most worlds, but usually will be controlled on worlds with Law Level 8+","shortdescr":"embedded armor","quantity":1,"weight":0,"price":15000,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"auglocation":"Full-Body","type":"augment","bonus":"+2 points armor","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_ak867xaq2cv","path":"Cepheus Deluxe - Items#/CF_SEP/Cybernetics","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.IhqWBhDF8OEfIidO"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rhlulHjVuPQm2eqi","name":"Internal Blade","type":"augment","img":"./systems/twodsix/assets/icons/internal-blade.svg","system":{"name":"","techLevel":9,"description":"A set of two 10cm retractable blades are implanted in the character’s limbs. These can be wrist blades, knuckle spikes, knee spikes, or even dew claws. The character’s unarmed attacks do 2D damage. The blades are constructed out of ceramic composites to avoid detection by most security scans. Only medical scans or TL13 or better sensors will detect the blades. Internal blades are considered illegal on world with Law Level 4+.<br>","shortdescr":"Unarmed attacks do 2D damage","quantity":1,"weight":0,"price":5000,"traits":[],"consumables":[],"skillModifier":0,"skill":"OKllPyuzWOGNPfLx","associatedSkillName":"Melee Combat","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"auglocation":"Full-Body","type":"augment","bonus":"unarmed damage 2D6","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_ak867xaq2cv","path":"Cepheus Deluxe - Items#/CF_SEP/Cybernetics","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.VtaIQmM0dDmUt2Uf"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":12500,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3,"JxqvtfhxiQMqjBjV":3},"flags":{"cf":{"id":"temp_rxguv8nhfha","path":"Sample NPCs","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-deluxe-actors.JMaj64wmR5TN13TO"}},"prototypeToken":{"name":"Elite Bodyguard","displayName":40,"actorLink":true,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":1,"displayBars":50,"bar1":{"attribute":"hits"},"bar2":{"attribute":null},"flags":{},"randomImg":false,"light":{"dim":0,"bright":0,"angle":360,"alpha":0.25,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"color":null,"coloration":1,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"darkness":{"min":0,"max":1}},"texture":{"src":"systems/twodsix/assets/icons/default_actor.png","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":true,"range":1000,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677872691588,"modifiedTime":1677872699239,"lastModifiedBy":"JxqvtfhxiQMqjBjV"},"_id":"0dnw7AQCVwacgG3N"}
{"name":"Diplomat","type":"traveller","img":"systems/twodsix/assets/icons/default_actor.png","system":{"name":"","homeWorld":"","nationality":"","species":"","age":{"value":"18","min":0},"hits":{"value":18,"min":0,"max":18,"lastDelta":0},"gender":"","radiationDose":{"value":"0","max":0,"min":0},"encumbrance":{"value":0,"max":0},"primaryArmor":{"value":"6"},"secondaryArmor":{"value":"0"},"heroPoints":2,"radiationProtection":{"value":"0"},"contacts":"","allies":"","enemies":"","untrainedSkill":"lN6fgWwhghX2Jvnc","description":"","bio":"","notes":"","finances":{"cash":"0","pension":"0","debt":"0","payments":"0","livingCosts":"0","financial-notes":""},"characteristics":{"strength":{"key":"strength","value":6,"damage":0,"label":"Strength","shortLabel":"STR","displayShortLabel":""},"dexterity":{"key":"dexterity","value":7,"damage":0,"label":"Dexterity","shortLabel":"DEX","displayShortLabel":""},"endurance":{"key":"endurance","value":6,"damage":0,"label":"Endurance","shortLabel":"END","displayShortLabel":""},"intelligence":{"key":"intelligence","value":10,"damage":0,"label":"Intelligence","shortLabel":"INT","displayShortLabel":""},"education":{"key":"education","value":13,"damage":0,"label":"Education","shortLabel":"EDU","displayShortLabel":""},"socialStanding":{"key":"socialStanding","value":14,"damage":0,"label":"Social Standing","shortLabel":"SOC","displayShortLabel":""},"psionicStrength":{"key":"psionicStrength","value":7,"damage":0,"label":"Psionic Strength","shortLabel":"PSI","displayShortLabel":""},"stamina":{"key":"stamina","value":6,"damage":0,"label":"Stamina","shortLabel":"STA","displayShortLabel":""},"lifeblood":{"key":"lifeblood","value":12,"damage":0,"label":"Lifeblood","shortLabel":"LFB","displayShortLabel":""},"alternative1":{"key":"alternative1","value":7,"damage":0,"label":"Alternative 1","shortLabel":"ALT1","displayShortLabel":""},"alternative2":{"key":"alternative2","value":7,"damage":0,"label":"Alternative 2","shortLabel":"ALT2","displayShortLabel":""}},"conditions":{"woundedEffect":0,"encumberedEffect":0},"characteristicEdit":false,"movement":{"burrow":0,"climb":0,"fly":0,"swim":0,"walk":0,"units":"","hover":false},"hideStoredItems":{"weapon":false,"armor":false,"augment":false,"equipment":false,"consumable":false,"attachment":false},"experience":{"value":0,"totalEarned":0},"xpNotes":""},"items":[{"_id":"lN6fgWwhghX2Jvnc","name":"Untrained","type":"skills","img":"icons/svg/item-bag.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":-3,"characteristic":"NONE","type":"skills","description":"","shortdescr":"","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"twodsix":{"untrainedSkill":true}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"JpkZYSW54EqcSX3K","name":"Admin","type":"skills","img":"./systems/twodsix/assets/icons/admin.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"EDU","type":"skills","description":"Administration: understanding and dealing with bureaucracies, businesses, and the law. Also covers forgery.<br><br>Examples: throw Admin/EDU 10+ to deal with a complex government bureaucracy and get permits. Throw Admin/INT opposed by Investigate/INT to pass off forged documents as authentic. Throw Admin/INT or Admin/SOC 10+ to bluff your way past a routine customs inspection.","shortdescr":"understanding and dealing with bureaucracies, businesses, and the law","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.YS1V8gReRrBqKIiu"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"Rr0SzLbfWedkuSiE","name":"Liaison","type":"skills","img":"./systems/twodsix/assets/icons/liaison.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":3,"characteristic":"SOC","type":"skills","description":"Liaison: negotiation and diplomacy in a myriad of social situations. This skill covers diplomatic meetings, haggling in interstellar trading negotiations, or at the shouq, and talking down a gunman who is holding hostages.<br><br>Examples: throw Liaison/SOC 8+ to strike a deal with a reluctant alien merchant. Throw Liaison/INT 8+ to read a room and negotiate with the person who really makes the decisions. Throw Liaison/EDU 10+ to understand proper etiquette when dealing with an honor-based culture. Throw Liaison/INT opposed by Liaison/INT to haggle over a price.","shortdescr":"Negotiation and diplomacy in a myriad of social situations","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.WGIiT2CCuzxPJd1x"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"hK7D8KbMmovVU2bK","name":"Deception","type":"skills","img":"./systems/twodsix/assets/icons/deception.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"SOC","type":"skills","description":"Deception: convincingly avoiding the truth and misleading other people. This skill covers sleight-of-hand and disguise as well.<br><br>Examples: throw Deception/SOC 10+ to lie your way past a corporate sentry while posing as a visiting executive. Throw Deception/INT opposed by Investigation/INT to lie during a police interrogation and not be found out. Throw Deception/END 12+ to fool a polygraph lie detector test. Throw Deception/DEX 10+ to palm a small item (can be opposed by Recon or Investigation).","shortdescr":"Convincingly avoiding the truth and misleading other people","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.iQIhVdEsFHhdELN0"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rXFxhrcTqeCVvl81","name":"Carousing","type":"skills","img":"./systems/twodsix/assets/icons/carousing.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"SOC","type":"skills","description":"Carousing: the art of mingling in social settings to achieve your goals. Also covers gambling.<br><br>Examples: throw Carousing/SOC 6+ to gather useful rumors at a party. Throw opposed Carousing/END to drink someone under the table.","shortdescr":"The art of mingling in social settings to achieve your goals","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.Ivc9wU3L8mFObSBW"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"3Gn7O37BgetYt7gu","name":"Investigation","type":"skills","img":"./systems/twodsix/assets/icons/investigate.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"INT","type":"skills","description":"Investigation: keen observation, forensics, research, and detailed analysis.<br><br>>Examples: throw Investigation/INT 6+ to locate and extract fingerprints from a crime scene. Throw Investigation/EDU 10+ (or opposed by someone’s Admin/EDU) to uncover evidence of fraud or other irregularities in a business’ accounting practices. Throw Investigation/INT 10+ to find hidden levers, or to notice that a crime scene was disturbed before being discovered. Throw Investigation/INT 8+ to perform surveillance on a target.","shortdescr":"This skill combines keen observation, forensics, research, and detailed analysis","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.isLeYQ7qxqaouJOW"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rimGXVgafwQ5Pgbr","name":"Computers","type":"skills","img":"./systems/twodsix/assets/icons/computers.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"EDU","type":"skills","description":"Computer: programming, working with computer hardware, and hacking. This skill also covers the use of sensors and communications gear.<br><br>Examples: throw Computer/EDU 8+ to purge malware from a computer. Throw Computer/EDU 12+ to hack a government server and download a database. Throw Opposed Computer/EDU to avoid detection and tracing while doing so.","shortdescr":"Programming, working with and hacking computer hardware; comms and sensors operation","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.3dz34XdGUGhAu0wc"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"PqvhXmRqVP9XpIgh","name":"Stealth Pistol","type":"weapon","img":"./systems/twodsix/assets/icons/body-pistol.svg","system":{"name":"Body Pistol","techLevel":8,"description":"This is an especially light, discreet, and concealable weapon made from advanced polymers. A concealed body pistol can also be disguised as a number of more innocuous items, like comms, digital recorders, and so on.<br><br>Double Tap: may fire 2 bullets in one attack to gain DM+1 to damage.","shortdescr":"Body Pistol - ranged","quantity":1,"weight":1,"price":500,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"Gun Combat","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"5/20","damage":"2d6","damageBonus":0,"magazineSize":0,"ammo":"6","useConsumableForAttack":"","magazineCost":20,"type":"weapon","location":"","lawLevel":"1","rangeBand":"5/20","weaponType":"ranged","damageType":"P - Double tap","rateOfFire":"1","recoil":true,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_sk461konhrd","path":"Cepheus Deluxe - Items#/CF_SEP/Weapons#/CF_SEP/Ranged Weapons","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.nGvTh4NNnhelRaRy"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"m8fFkjK7jh6VojUo","name":"Heavy Ballistic Cloth","type":"armor","img":"./systems/twodsix/assets/icons/cloth.svg","system":{"name":"","techLevel":7,"description":"A modern heavy-duty ballistic- cloth armor. Commonly worn by soldiers, well-equipped security, and TL7 mercenaries. Counts as two Items for encumbrance purposes and is not concealable.","shortdescr":"modern heavy-duty ballistic-cloth armor","quantity":1,"weight":2,"price":250,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"armor":6,"secondaryArmor":{"value":0},"radiationProtection":{"value":0},"type":"armor","useConsumableForAttack":"","location":["inventory","storage"],"isPowered":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"exportSource":{"world":"on_the_run","system":"twodsix","coreVersion":"0.6.6","systemVersion":"0.6.27"},"cf":{"id":"temp_3odrbwitf0c","path":"Cepheus Deluxe - Items#/CF_SEP/Armor","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.EKKJ33cnnnmKvcHo"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"tXH5wKntQA6e3Fuq","name":"Omnicomm","type":"equipment","img":"systems/twodsix/assets/icons/omnicomm.svg","system":{"name":"","techLevel":8,"description":"Today’s smartphones will eventually evolve into an Omnicomm, a combination of all your telecom needs in one place, with holographic augmented reality capability. Designed to integrate with whatever telecommunications networks are present on a given world. TL8 batteries for these devices last for a few days; TL9 batteries last for months between recharging.","shortdescr":"smart communicator","quantity":1,"weight":1,"price":50,"traits":[],"consumables":[],"skillModifier":0,"skill":"rimGXVgafwQ5Pgbr","associatedSkillName":"Computers","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_bpg3uct3zcp","path":"Cepheus Deluxe - Items#/CF_SEP/Equipment","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.MlLa4SgNWAZAdwQk"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":100000,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3,"JxqvtfhxiQMqjBjV":3},"flags":{"cf":{"id":"temp_rxguv8nhfha","path":"Sample NPCs","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-deluxe-actors.Y4tK9qU914H2IcZR"}},"prototypeToken":{"name":"Diplomat","displayName":40,"actorLink":true,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":1,"displayBars":50,"bar1":{"attribute":"hits"},"bar2":{"attribute":null},"flags":{},"randomImg":false,"light":{"dim":0,"bright":0,"angle":360,"alpha":0.25,"animation":{"speed":5,"intensity":5,"type":null,"reverse":false},"color":null,"coloration":1,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"darkness":{"min":0,"max":1}},"texture":{"src":"systems/twodsix/assets/icons/default_actor.png","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":true,"range":1000,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677872665760,"modifiedTime":1677872665777,"lastModifiedBy":"JxqvtfhxiQMqjBjV"},"_id":"OLMsYc8gHrxq23xv"}
{"name":"Elite Bodyguard","type":"traveller","img":"systems/twodsix/assets/icons/default_actor.png","system":{"name":"","homeWorld":"","nationality":"","species":"","age":{"value":"","min":0},"hits":{"value":36,"min":0,"max":36,"lastDelta":0},"gender":"","radiationDose":{"value":0,"max":0,"min":0},"encumbrance":{"value":0,"max":0},"primaryArmor":{"value":"8"},"secondaryArmor":{"value":"0"},"heroPoints":2,"radiationProtection":{"value":"0"},"contacts":"","allies":"","enemies":"","untrainedSkill":"pyDEKKXipO2fX7A7","description":"","bio":"","notes":"","finances":{"cash":"0","pension":"0","debt":"0","payments":"0","livingCosts":"0","financial-notes":""},"characteristics":{"strength":{"key":"strength","value":10,"damage":0,"label":"Strength","shortLabel":"STR","displayShortLabel":""},"dexterity":{"key":"dexterity","value":9,"damage":0,"label":"Dexterity","shortLabel":"DEX","displayShortLabel":""},"endurance":{"key":"endurance","value":10,"damage":0,"label":"Endurance","shortLabel":"END","displayShortLabel":""},"intelligence":{"key":"intelligence","value":7,"damage":0,"label":"Intelligence","shortLabel":"INT","displayShortLabel":""},"education":{"key":"education","value":7,"damage":0,"label":"Education","shortLabel":"EDU","displayShortLabel":""},"socialStanding":{"key":"socialStanding","value":7,"damage":0,"label":"Social Standing","shortLabel":"SOC","displayShortLabel":""},"psionicStrength":{"key":"psionicStrength","value":7,"damage":0,"label":"Psionic Strength","shortLabel":"PSI","displayShortLabel":""},"stamina":{"key":"stamina","value":12,"damage":0,"label":"Stamina","shortLabel":"STA","displayShortLabel":""},"lifeblood":{"key":"lifeblood","value":24,"damage":0,"label":"Lifeblood","shortLabel":"LFB","displayShortLabel":""},"alternative1":{"key":"alternative1","value":7,"damage":0,"label":"Alternative 1","shortLabel":"ALT1","displayShortLabel":""},"alternative2":{"key":"alternative2","value":7,"damage":0,"label":"Alternative 2","shortLabel":"ALT2","displayShortLabel":""}},"conditions":{"woundedEffect":0,"encumberedEffect":0},"characteristicEdit":false,"movement":{"burrow":0,"climb":0,"fly":0,"swim":0,"walk":0,"units":"ft","hover":false},"hideStoredItems":{"weapon":false,"armor":false,"augment":false,"equipment":false,"consumable":false,"attachment":false},"experience":{"value":0,"totalEarned":0},"xpNotes":""},"items":[{"_id":"pyDEKKXipO2fX7A7","name":"Untrained","type":"skills","img":"icons/svg/item-bag.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":-3,"characteristic":"NONE","type":"skills","description":"","shortdescr":"","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"twodsix":{"untrainedSkill":true}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"bCdaqVG6HcFZhcSA","name":"Gun Combat","type":"skills","img":"./systems/twodsix/assets/icons/gun-combat.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":3,"characteristic":"DEX","type":"skills","description":"Gun Combat: using small arms, crossbows, and bows in combat.<br><br>Examples: throw Gun Combat/DEX 8+ to hit a target in Effective range with a handgun. Throw Gun combat/DEX 10+ to hit a target at Maximum range. See the Combat chapter for more information.","shortdescr":"Using small arms, crossbows, and bows in combat","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.enQOAVdQXndSdf0j"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"OKllPyuzWOGNPfLx","name":"Melee Combat","type":"skills","img":"./systems/twodsix/assets/icons/melee.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":3,"characteristic":"STR","type":"skills","description":"Melee Combat: fighting hand-to-hand, either with a weapon or unarmed.<br><br>Examples: throw Melee Combat/STR 8+ to hit a target with a sword. The Combat chapter has more detailed examples of how to use the Melee Combat skill.","shortdescr":"Fighting hand-to-hand, either with a weapon or unarmed","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.eVVFG5oHgsBycy1K"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"VjcUZ6smeBW97B1u","name":"Athletics","type":"skills","img":"./systems/twodsix/assets/icons/athletics-dexterity.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"END","type":"skills","description":"Athletics: the ability to exert oneself physically. You may add the Athletics skill to appropriate physical characteristic rolls. This skill is never rolled unskilled.<br><br>Examples: throw Athletics/END 6+ to swim against a powerful current. To move past obstacles while running, using Parkour-style moves, throw Athletics/DEX 8+. To climb a rope quickly, throw Athletics/STR 8+.","shortdescr":"The ability to exert oneself physically","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.bupjJOC81mWCqwd4"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"v0mXl7kfPCwl4ihq","name":"Recon","type":"skills","img":"./systems/twodsix/assets/icons/recon.svg","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"INT","type":"skills","description":"Recon: scouting for danger and spotting threats, including traps. Recon also covers performing forward observation for artillery.<br><br>Examples: throw Recon/INT 8+ to correctly identify the composition of a concealed enemy force. Throw Recon/INT 10+ to identify a likely ambush kill zone. Throw Recon/INT 10+ to call down an airstrike on a large stationary target, such as a building. Throw Recon/INT 8+ to track a target in the wilderness. Throw Recon/INT 12+ to locate a devilishly hidden trap.","shortdescr":"Scouting for danger and spotting threats, including traps","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","reference":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_3btd7dw9pac","path":"Cepheus Deluxe - Items#/CF_SEP/Skills","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.hKNf0aBpr4jX4I1w"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"Otl7gtXdhN23mf9K","name":"Gauss Pistol","type":"weapon","img":"./systems/twodsix/assets/icons/gauss-pistol.svg","system":{"name":"Gauss Rifle","techLevel":12,"description":"These weapons accelerate small metal spikes to supersonic velocities. Though the principles behind their function have been understood since the early industrial age, Gauss weapons are typically beyond the manufacturing capabilities of frontier worlds. They do appear, from time to time, in the hands of well-equipped mercenary forces.<br><br>Auto 2: These weapons fire multiple rounds with every pull of the trigger, filling the air with a hail of fire. A weapon with the Auto aspect can make attacks in three fire modes: single, burst, and full auto, as described in the Combat chapter.","shortdescr":"Gauss Pistol - ranged","quantity":1,"weight":1,"price":1000,"traits":[],"consumables":[],"skillModifier":0,"skill":"bCdaqVG6HcFZhcSA","associatedSkillName":"Gun Combat","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"20/100","damage":"3d6","damageBonus":0,"magazineSize":0,"ammo":"30","useConsumableForAttack":"","magazineCost":30,"type":"weapon","location":"","lawLevel":"6","rangeBand":"20/100","weaponType":"ranged","damageType":"P - AV 1D, Auto 2","rateOfFire":"2","recoil":false,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_sk461konhrd","path":"Cepheus Deluxe - Items#/CF_SEP/Weapons#/CF_SEP/Ranged Weapons","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.796fjj1h1cJWoI9L"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"CSj0Wzy3FeT2wHnB","name":"Heavy Ballistic Cloth","type":"armor","img":"./systems/twodsix/assets/icons/cloth.svg","system":{"name":"","techLevel":7,"description":"A modern heavy-duty ballistic- cloth armor. Commonly worn by soldiers, well-equipped security, and TL7 mercenaries. Counts as two Items for encumbrance purposes and is not concealable.","shortdescr":"modern heavy-duty ballistic-cloth armor","quantity":1,"weight":2,"price":250,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"armor":6,"secondaryArmor":{"value":0},"radiationProtection":{"value":0},"type":"armor","useConsumableForAttack":"","location":["inventory","storage"],"isPowered":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"exportSource":{"world":"on_the_run","system":"twodsix","coreVersion":"0.6.6","systemVersion":"0.6.27"},"cf":{"id":"temp_3odrbwitf0c","path":"Cepheus Deluxe - Items#/CF_SEP/Armor","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.EKKJ33cnnnmKvcHo"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ZQ60TQh22In5eLgN","name":"Medkit","type":"equipment","img":"systems/twodsix/assets/icons/medkit.svg","system":{"name":"","techLevel":8,"description":"","shortdescr":"Medkit","quantity":1,"weight":1,"price":100,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"Medicine","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_bpg3uct3zcp","path":"Cepheus Deluxe - Items#/CF_SEP/Equipment","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.JlAnmUJ4vsv6RfjC"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"JsYaCTyOevH9Wczo","name":"Omnicomm","type":"equipment","img":"systems/twodsix/assets/icons/omnicomm.svg","system":{"name":"","techLevel":8,"description":"Today’s smartphones will eventually evolve into an Omnicomm, a combination of all your telecom needs in one place, with holographic augmented reality capability. Designed to integrate with whatever telecommunications networks are present on a given world. TL8 batteries for these devices last for a few days; TL9 batteries last for months between recharging.","shortdescr":"smart communicator","quantity":1,"weight":1,"price":50,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"Computers","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_bpg3uct3zcp","path":"Cepheus Deluxe - Items#/CF_SEP/Equipment","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.MlLa4SgNWAZAdwQk"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"3A2KhScjhlNfxb6q","name":"Subdermal Armor","type":"augment","img":"./systems/twodsix/assets/icons/subdermal-armor.svg","system":{"name":"","techLevel":9,"description":"Keratin and ceramic bone lacing and light shielding of vital organs provides 2 points of armor protection. The implant is subtle enough to pass visual inspection but can be spotted with sensor scans. Subdermal armor is added to the protection rating of any worn armor. Subdermal armor is legal on most worlds, but usually will be controlled on worlds with Law Level 8+","shortdescr":"embedded armor","quantity":1,"weight":0,"price":15000,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"auglocation":"Full-Body","type":"augment","bonus":"+2 points armor","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_ak867xaq2cv","path":"Cepheus Deluxe - Items#/CF_SEP/Cybernetics","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.IhqWBhDF8OEfIidO"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"rhlulHjVuPQm2eqi","name":"Internal Blade","type":"augment","img":"./systems/twodsix/assets/icons/internal-blade.svg","system":{"name":"","techLevel":9,"description":"A set of two 10cm retractable blades are implanted in the character’s limbs. These can be wrist blades, knuckle spikes, knee spikes, or even dew claws. The character’s unarmed attacks do 2D damage. The blades are constructed out of ceramic composites to avoid detection by most security scans. Only medical scans or TL13 or better sensors will detect the blades. Internal blades are considered illegal on world with Law Level 4+.<br>","shortdescr":"Unarmed attacks do 2D damage","quantity":1,"weight":0,"price":5000,"traits":[],"consumables":[],"skillModifier":0,"skill":"OKllPyuzWOGNPfLx","associatedSkillName":"Melee Combat","equipped":{"weight":0},"docReference":"","pdfReference":{"type":"","href":"","label":""},"auglocation":"Full-Body","type":"augment","bonus":"unarmed damage 2D6","location":["inventory","storage"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3},"flags":{"cf":{"id":"temp_ak867xaq2cv","path":"Cepheus Deluxe - Items#/CF_SEP/Cybernetics","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-light-items.VtaIQmM0dDmUt2Uf"}},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":25000,"ownership":{"default":0,"GOmBKof9PfoHZ54T":3,"JxqvtfhxiQMqjBjV":3},"flags":{"cf":{"id":"temp_rxguv8nhfha","path":"Sample NPCs","color":"#00aaaa"},"core":{"sourceId":"Compendium.twodsix.cepheus-deluxe-actors.JMaj64wmR5TN13TO"}},"prototypeToken":{"name":"Elite Bodyguard","displayName":40,"actorLink":true,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":