rence":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"STR","type":"skills","description":"The character is skilled at using advanced energy weapons like laser rifles or plasma rifles.","shortdescr":"The character is skilled at using advanced energy weapons like laser rifles or plasma rifles.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Gun Combat (Energy Rifle)","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/gun-combat-energy-rifle.svg","effects":[],"_id":"wszJL09VlTayAFzi","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943043124,"modifiedTime":1677943050538,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Mechanics","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"The character is practiced in installing, using, maintaining, repairing and/or creating mechanical devices and equipment. The character can practice a trade and make a decent living, earning a paycheck for every week of dedicated work. The character knows how to use the tools of the trade, how to perform routine tasks, how to supervise untrained helpers, and how to handle common problems.   Disabling Devices: The character is skilled at disabling mechanical alarm systems, picking mechanical locks, or similar tasks involving mechanical devices.","shortdescr":"The character is practiced in installing, using, maintaining, repairing and/or creating mechanical devices and equipment.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Mechanics","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/mechanic.svg","effects":[],"_id":"HYZS60oULs2DBtb8","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943060275,"modifiedTime":1677943069370,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Recon","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"This skill represents the ability to scout out dangers and spot threats, unusual objects or out of place people. Characters skilled in Recon are adept at staying unseen and unheard.","shortdescr":"This skill represents the ability to scout out dangers and spot threats, unusual objects or out of place people.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Recon","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/recon.svg","effects":[],"_id":"YL8QxFIqVdCNaToJ","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943071930,"modifiedTime":1677943073898,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Tactics","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"This skill covers tactical planning and decision making, from board games to squad level combat to fleet engagements.","shortdescr":"This skill covers tactical planning and decision making, from board games to squad level combat to fleet engagements.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Tactics","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/tactics.svg","effects":[],"_id":"OIdpCoVctHext1dq","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943088109,"modifiedTime":1677943090762,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Demolitions","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"This skill covers the use of demolition charges and other explosive devices, including assembling or disarming bombs.","shortdescr":"This skill covers the use of demolition charges and other explosive devices, including assembling or disarming bombs.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Demolitions","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/demolition_explosives.svg","effects":[],"_id":"6gIcvavJnE7Y1dYj","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943104187,"modifiedTime":1677943105803,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Athletics","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"This skill covers physical fitness and training, similar to that of a trained athlete. This includes acts requiring physical coordination, such as climbing, juggling or throwing, acts of endurance, such as long-distance running or hiking, and acts of strength, such as weight-lifting or bodybuilding.   Aliens with Wings: For alien species with wings, this skill is also used to reflect their ability to fly.","shortdescr":"This skill covers physical fitness and training, similar to that of a trained athlete.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Athletics","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/athletics-dexterity.svg","effects":[],"_id":"h8MD1Hj5POXIk9T5","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943112636,"modifiedTime":1677943114538,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Engineering","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"The character is skilled in the operation and maintenance of starship maneuver drives, Jump drives, and power plants. The character can practice a trade and make a decent living, earning a paycheck for every week of dedicated work. The character knows how to use the tools of the trade, how to perform routine tasks, how to supervise untrained helpers, and how to handle common problems. Engineering is particularly important in diverting power to the Jump Drives for a successful transition into Jump space.","shortdescr":"The character is skilled in the operation and maintenance of starship maneuver drives, Jump drives, and power plants.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Engineering","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/engineering.svg","effects":[],"_id":"10ZywEfmHj9tRZNV","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943125155,"modifiedTime":1677943126666,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Melee Combat (Piercing Weapons)","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"The character is skilled at using piercing and thrusting weapons, such as spears and polearms, in personal combat.","shortdescr":"The character is skilled at using piercing and thrusting weapons, such as spears and polearms, in personal combat.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Melee Combat (Piercing Weapons)","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/melee-combat-piercing-weapons.svg","effects":[],"_id":"n6SI0XBRyYuF5cpS","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943146674,"modifiedTime":1677943148395,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Zero-G","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"The character is acclimated to working and living in micro-gravity environments and freefall. The character is trained and familiar with the use of weapons and combat in such environments. In addition, the individual has been trained in the wearing, care, and maintenance of all types of Vacuum Suits and Combat Armor commonly used in these conditions.","shortdescr":"The character is acclimated to working and living in micro-gravity environments and freefall.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Zero-G","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"icons/svg/mystery-man.svg","effects":[],"_id":"zGHNzgIY0bOK79sS","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943156466,"modifiedTime":1677943158666,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"ZQguzaTaWFVfGWnh","name":"Combat Armor","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"armor","system":{"name":"","techLevel":10,"description":"<div>This full-body suit is used by the military and not generally available on the open market, although those with military or criminal contacts can obtain it without much difficulty. It is issued to troop units and mercenary battalions. Combat armor protects from hard vacuum in the same way as a vacc suit and provides life support for six hours.</div><div><br></div><div>Requires Zero G skill.<br></div>","shortdescr":"Combat Armor (TL 11)","quantity":1,"weight":18,"price":20000,"traits":[],"consumables":[],"skillModifier":0,"skill":"h8MD1Hj5POXIk9T5","associatedSkillName":"","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"armor":13,"secondaryArmor":{"value":0},"radiationProtection":{"value":0},"type":"armor","useConsumableForAttack":"","location":["inventory","storage"],"isPowered":false},"flags":{"cf":{"id":"temp_otghevd6kk","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Armor","color":"#000000"}},"img":"systems/twodsix/assets/icons/Combat-armor.svg","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943185346,"modifiedTime":1677943333511,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"1VQCpWZdWh86FlCe","name":"Laser Rifle","type":"weapon","img":"systems/twodsix/assets/icons/laser-rifle.svg","system":{"name":"Laser Rifle","techLevel":9,"description":"The standard high energy weapon, firing energy bolts in the same manner as the laser carbine. Heavier, the laser rifle is also capable of longer sustained action, and is somewhat sturdier. The power pack can provide 100 shots before recharging. As in the laser carbine, the laser rifle is connected to the power pack by a heavy-duty cable. Power packs are not interchangeable between the two weapons, however.","shortdescr":"Laser Rifle - ranged","quantity":1,"weight":6,"price":3500,"traits":[],"consumables":[],"skillModifier":0,"skill":"wszJL09VlTayAFzi","associatedSkillName":"Gun Combat (Energy Rifle)","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"0","damage":"5d6","damageBonus":0,"magazineSize":100,"ammo":"100","useConsumableForAttack":"","magazineCost":300,"type":"weapon","location":"","lawLevel":"2","rangeBand":"rifle","weaponType":"ranged","damageType":"E","rateOfFire":"1","recoil":true,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"TZxGG8c7kFt1cyHi":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_7b2zwn0irpt"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943288674,"modifiedTime":1677943341391,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"6rvq1zSOdE49UeQi","name":"Dagger","type":"weapon","img":"systems/twodsix/assets/icons/dagger.svg","system":{"name":"Dagger","techLevel":0,"description":"A small knife weapon with a flat, two-edged blade approximately 200mm in length. Daggers are usually carried in a belt sheath, or less frequently concealed in a boot sheath or strapped to the forearm. Daggers are usually as much a tool as a last-resort weapon of defense, and worn constantly. Each weighs 250 grams; that weight, however, does not count against the weight load of the character as the weapon is worn constantly and comfortably.","shortdescr":"Dagger - melee","quantity":1,"weight":0.25,"price":10,"traits":[],"consumables":[],"skillModifier":0,"skill":"n6SI0XBRyYuF5cpS","associatedSkillName":"Melee Combat (Piercing Weapons)","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":0,"damage":"1d6","damageBonus":0,"magazineSize":0,"ammo":"0","useConsumableForAttack":"","magazineCost":0,"type":"weapon","location":"","lawLevel":"5","rangeBand":"reach or thrown","weaponType":"melee","damageType":"P","rateOfFire":"","recoil":true,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"TZxGG8c7kFt1cyHi":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_7b2zwn0irpt"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943308442,"modifiedTime":1677943340424,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"vBUeiT9JAIRD7L4Q","name":"Smoke","type":"weapon","img":"systems/twodsix/assets/icons/smoke.svg","system":{"name":"","techLevel":6,"description":"Smoke grenades create a thick cloud of smoke six meters in radius, centered on the location of the grenade. This smoke imposes a –2 DM on all attacks within or through the cloud (doubled for laser weapons). Smoke dissipates in 1D6x3 rounds, although high winds and other extreme weather can sharply reduce this time.","shortdescr":"Smoke - special","quantity":6,"weight":0.5,"price":90,"traits":[],"consumables":[],"skillModifier":0,"skill":"6gIcvavJnE7Y1dYj","associatedSkillName":"Demolitions","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":0,"damage":"","damageBonus":0,"magazineSize":0,"ammo":"","useConsumableForAttack":"","magazineCost":0,"type":"weapon","location":["inventory","storage"],"lawLevel":"0","rangeBand":"","weaponType":"","damageType":"","rateOfFire":"","recoil":false,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_5ujlm40ozw3","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Grenades and Explosives","color":"#000000"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943387600,"modifiedTime":1677943387659,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"YCvgNyw9XaYHopR7","name":"Stun","type":"weapon","img":"systems/twodsix/assets/icons/flashbang.svg","system":{"name":"","techLevel":9,"description":"Stun weapons, such as stun grenades, are non-lethal and do not inflict normal damage. A character within six meters of a stun grenade detonation must make an Endurance check with a negative DM equal to the damage (after armor is subtracted). If this Endurance check is failed the character is knocked unconscious. If the Endurance check is successful, the character is unaffected by the weapon and the stun damage is ignored.","shortdescr":"Stun","quantity":6,"weight":0.5,"price":180,"traits":[],"consumables":[],"skillModifier":0,"skill":"6gIcvavJnE7Y1dYj","associatedSkillName":"Demolitions","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":0,"damage":"3d6","damageBonus":0,"magazineSize":0,"ammo":"0","useConsumableForAttack":"","magazineCost":0,"type":"weapon","location":["inventory","storage"],"lawLevel":"0","rangeBand":"","weaponType":"","damageType":"stun","rateOfFire":"","recoil":false,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_5ujlm40ozw3","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Grenades and Explosives","color":"#000000"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677943391059,"modifiedTime":1677943391120,"lastModifiedBy":"H829Kq6g80UJ9CuX"}}],"effects":[],"sort":0,"ownership":{"default":0,"H829Kq6g80UJ9CuX":3},"flags":{},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677942969908,"modifiedTime":1678289210380,"lastModifiedBy":"H829Kq6g80UJ9CuX"},"_id":"8hXgr4jtbUBPB20q"}
