mm, 10 gram bullet at a velocity of approximately 900 meters per second. Longer and heavier than a carbine, it is also more effective. Standard equipment includes provisions for attaching a bayonet and telescopic sights, and a shoulder sling. A twenty-round magazine is attached to the front of the trigger guard, and one round is fired with each pull of the trigger. Replacement of the empty magazine requires a reload action. Rifle ammunition may also be used in automatic rifles; rifle and auto rifle magazines are interchangeable, and weigh the same.","shortdescr":"Rifle - ranged","quantity":1,"weight":4,"price":200,"traits":[],"consumables":[],"skillModifier":0,"skill":"mSC42SrK75P52AZJ","associatedSkillName":"Gun Combat (Slug Rifle)","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"0","damage":"3d6","damageBonus":0,"magazineSize":20,"ammo":"20","useConsumableForAttack":"","magazineCost":20,"type":"weapon","location":"","lawLevel":"6","rangeBand":"rifle","weaponType":"ranged","damageType":"P","rateOfFire":"1","recoil":true,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"TZxGG8c7kFt1cyHi":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_7b2zwn0irpt"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677942184353,"modifiedTime":1677942299069,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"zUkpEt6na0b9KT9n","name":"Flak","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"armor","system":{"name":"","techLevel":8,"description":"A heavy duty body suit tailored from ballistic cloth. The fabric absorbs impact energy and spreads it over the body, which can result in bruising. However, cloth armor is highly useful and versatile – it can be effectively concealed under normal clothing although observers making an Investigate or Recon check at 8+ will notice something unusual.","shortdescr":"Cloth (TL 7)","quantity":1,"weight":2,"price":250,"traits":[],"consumables":[],"skillModifier":0,"skill":"w41N0sTBcXy9Vb4d","associatedSkillName":"","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"armor":5,"secondaryArmor":{"value":0},"radiationProtection":{"value":0},"type":"armor","useConsumableForAttack":"","location":["inventory","storage"],"isPowered":false},"flags":{"cf":{"id":"temp_otghevd6kk","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Armor","color":"#000000"}},"img":"systems/twodsix/assets/icons/cloth.svg","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677942632396,"modifiedTime":1677942678690,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"Aqo8zDdgKqpT6oyu","name":"Tarpaulin","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"equipment","system":{"name":"","techLevel":1,"description":"A heavy hard-wearing waterproof fabric made of canvas or similar, for outdoor use as a temporary shelter or protective covering against moisture. Measures 4 meters long by 2 meters wide.","shortdescr":"Tarp","quantity":1,"weight":2,"price":10,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"flags":{"cf":{"id":"temp_9sigdpo13em","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Shelters","color":"#000000"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677942815571,"modifiedTime":1677942815599,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"PqsUjuQcFcpDrOA6","name":"Short Range Communicator","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"equipment","system":{"name":"","techLevel":5,"description":"Belt-mounted radio capable of 10 km range (much shorter underground or underwater). Three separate channels. At tech level 7 reduce the weight to 300 grams and it becomes hand- held.","shortdescr":"Short Range Communicator - 10 km","quantity":1,"weight":5,"price":100,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"flags":{"cf":{"id":"temp_ahkqp5k1isf","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Communicators","color":"#000000"}},"img":"systems/twodsix/assets/icons/short-range-communicator.svg","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677942892947,"modifiedTime":1677942892977,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"o7W8WbjO4LDqsilv","name":"Electric Torch","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"equipment","system":{"name":"","techLevel":5,"description":"The common flashlight. It is battery powered and will last for about 6 hours of continuous use. A torch produces a wide cone of light up to 18 meters long with a radius of 6 meters at the end of the beam. Later TL models have adjustable beams allowing them to also produce a tight beam of light up to 36 meters long, with a 1 meter radius, or be used to illuminate a circle of 10 meter radius.<br>","shortdescr":"Flashlight","quantity":1,"weight":0.5,"price":10,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"type":"equipment","useConsumableForAttack":"","location":["inventory","storage"]},"flags":{"cf":{"id":"temp_q959auq6gs","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Sensory Aids","co