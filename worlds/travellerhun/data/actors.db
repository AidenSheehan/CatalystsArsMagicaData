3.75,"price":150,"traits":[],"consumables":[],"skillModifier":0,"skill":"yxkuvHM67xVE6JNa","associatedSkillName":"Gun Combat (Shotguns)","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":"0","damage":"4d6","damageBonus":0,"magazineSize":10,"ammo":"10","useConsumableForAttack":"","magazineCost":10,"type":"weapon","location":"","lawLevel":"7","rangeBand":"shotgun","weaponType":"ranged","damageType":"P","rateOfFire":"1","recoil":true,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"TZxGG8c7kFt1cyHi":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_7b2zwn0irpt"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1678289921021,"modifiedTime":1678289939253,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"General skills","type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"","shortdescr":"","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":""},"_id":"mfJt6OEV2gE8p5FE","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0,"H829Kq6g80UJ9CuX":3},"flags":{},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1678289970384,"modifiedTime":1678289986998,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"LVdtqKRLqTTy5ygk","name":"Cloth","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"armor","system":{"name":"","techLevel":7,"description":"A heavy duty body suit tailored from ballistic cloth. The fabric absorbs impact energy and spreads it over the body, which can result in bruising. However, cloth armor is highly useful and versatile – it can be effectively concealed under normal clothing although observers making an Investigate or Recon check at 8+ will notice something unusual.","shortdescr":"Cloth (TL 7)","quantity":1,"weight":2,"price":250,"traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"armor":9,"secondaryArmor":{"value":0},"radiationProtection":{"value":0},"type":"armor","useConsumableForAttack":"","location":["inventory","storage"],"isPowered":false},"flags":{"cf":{"id":"temp_otghevd6kk","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Armor","color":"#000000"}},"img":"systems/twodsix/assets/icons/cloth.svg","effects":[],"folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1678290132912,"modifiedTime":1678290207955,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"KfAOGJUBMMCJ9zZ9","name":"Stun","type":"weapon","img":"systems/twodsix/assets/icons/flashbang.svg","system":{"name":"","techLevel":9,"description":"Stun weapons, such as stun grenades, are non-lethal and do not inflict normal damage. A character within six meters of a stun grenade detonation must make an Endurance check with a negative DM equal to the damage (after armor is subtracted). If this Endurance check is failed the character is knocked unconscious. If the Endurance check is successful, the character is unaffected by the weapon and the stun damage is ignored.","shortdescr":"Stun","quantity":12,"weight":0.5,"price":180,"traits":[],"consumables":[],"skillModifier":0,"skill":"AJcGriE6ABW8vKV8","associatedSkillName":"Demolitions","equipped":"equipped","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":0,"damage":"3d6","damageBonus":0,"magazineSize":0,"ammo":"0","useConsumableForAttack":"","magazineCost":0,"type":"weapon","location":["inventory","storage"],"lawLevel":"0","rangeBand":"","weaponType":"","damageType":"stun","rateOfFire":"","recoil":false,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_5ujlm40ozw3","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Grenades and Explosives","color":"#000000"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1678290165535,"modifiedTime":1678290205366,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"5m7hJrHChrJUC9AN","name":"Smoke","type":"weapon","img":"systems/twodsix/assets/icons/smoke.svg","system":{"name":"","techLevel":6,"description":"Smoke grenades create a thick cloud of smoke six meters in radius, centered on the location of the grenade. This smoke imposes a –2 DM on all attacks within or through the cloud (doubled for laser weapons). Smoke dissipates in 1D6x3 rounds, although high winds and other extreme weather can sharply reduce this time.","shortdescr":"Smoke - special","quantity":6,"weight":0.5,"price":90,"traits":[],"consumables":[],"skillModifier":0,"skill":"AJcGriE6ABW8vKV8","associatedSkillName":"Demolitions","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":0,"damage":"","damageBonus":0,"magazineSize":0,"ammo":"","useConsumableForAttack":"","magazineCost":0,"type":"weapon","location":["inventory","storage"],"lawLevel":"0","rangeBand":"","weaponType":"","damageType":"","rateOfFire":"","recoil":false,"features":"","armorPiercing":0,"handlingModifiers":""},"effects":[],"folder":null,"sort":0,"ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"flags":{"cf":{"id":"temp_5ujlm40ozw3","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Grenades and Explosives","color":"#000000"}},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1678290200992,"modifiedTime":1678290201076,"lastModifiedBy":"H829Kq6g80UJ9CuX"}}],"effects":[],"flag