"}},"conditions":{"woundedEffect":0,"encumberedEffect":0},"characteristicEdit":false,"movement":{"burrow":0,"climb":0,"fly":0,"swim":0,"walk":0,"units":"ft","hover":false},"hideStoredItems":{"weapon":false,"armor":false,"augment":false,"equipment":false,"consumable":false,"attachment":false},"experience":{"value":0,"totalEarned":0},"xpNotes":""},"prototypeToken":{"name":"Cres Nemes","displayName":40,"actorLink":true,"texture":{"src":"worlds/travellerhun/assets/tokens/Cres_Noble_Officer.png","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"disposition":1,"displayBars":50,"bar1":{"attribute":"hits"},"bar2":{"attribute":null},"light":{"alpha":0.5,"angle":360,"bright":0,"color":null,"coloration":1,"dim":0,"attenuation":0.5,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"type":null,"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"sight":{"enabled":true,"range":1000,"angle":360,"visionMode":"basic","color":null,"attenuation":0.1,"brightness":1,"saturation":0,"contrast":0},"detectionModes":[],"flags":{},"randomImg":false},"items":[{"name":"Untrained","type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":-3,"characteristic":"NONE","type":"skills","description":"","shortdescr":"","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":""},"flags":{"twodsix":{"untrainedSkill":true}},"img":"./systems/twodsix/assets/icons/jack-of-all-trades.svg","_id":"WVeCBjnU96PM2KdD","effects":[],"folder":null,"sort":0,"ownership":{"default":0,"H829Kq6g80UJ9CuX":3},"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677944901299,"modifiedTime":1677944901299,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Admin","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"The character has experience with bureaucratic agencies, and understands the requirements of dealing with and managing them. When attempting tasks like avoiding police harassment, ensuring the prompt issuance of licenses, approval of applications, avoidance of close inspection of papers, etc., a successful Admin skill check (with a Difficulty based on Base Difficulty by Law Level table), will provide a positive outcome to the situation.","shortdescr":"The character has experience with bureaucratic agencies, and understands the requirements of dealing with and managing them.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Admin","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/admin.svg","effects":[],"_id":"UT3tCTRQlIqtqnqZ","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677944960616,"modifiedTime":1677944963137,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Advocate","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"The character is familiar with the general laws and regulations that govern interstellar travel, commerce and relations. This skill does not impart knowledge of the myriad of laws on each individual world, nor does it allow the person to act as an attorney","shortdescr":"The character is familiar with the general laws and regulations that govern interstellar travel, commerce and relations.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Advocate","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/advocate.svg","effects":[],"_id":"HvQdu61dIvD1DEyv","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677944965338,"modifiedTime":1677944968529,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Carousing","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"This skill reflects the interpersonal art of interacting and socializing with others. The character is skilled in the art of small talk and making others feel at ease in their presence in almost any social situation, such as a party, ball, inauguration, bar hopping, etc.","shortdescr":"This skill reflects the interpersonal art of interacting and socializing with others.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Carousing","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/carousing.svg","effects":[],"_id":"0B5DLut7HXrPkS5T","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945023721,"modifiedTime":1677945026225,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Leadership","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":2,"characteristic":"STR","type":"skills","description":"The character possesses the ability to rally, inspire, organize and direct team efforts to ensure the best cooperation and productivity possible.   Coordinating Effort: Whenever a task requires one or more characters to combine their efforts (i.e. Teamwork, each makes a skill or ability check towards a common goal), the character gains a pool of points equal to the Effect of the skill check (minimum of 1), which can be distributed by the leader to individual team members as DMs (grant a +1 DM per point) on skill or ability checks made toward the common goal.   Improving Initiative: The Leadership skill can be used to increase another character's Initiative. The character with Leadership makes a Leadership check, and the target character's Initiative is increased by the Effect of the check. Making a Leadership skill check is a significant action.","shortdescr":"The character possesses the ability to rally, inspire, organize and direct team efforts to ensure the best cooperation and productivity possible.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Leadership","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/leadership.svg","effects":[],"_id":"6aJSvLwpz0Q7dLUk","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945055635,"modifiedTime":1677945061457,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Tactics","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"This skill covers tactical planning and decision making, from board games to squad level combat to fleet engagements.","shortdescr":"This skill covers tactical planning and decision making, from board games to squad level combat to fleet engagements.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Tactics","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/tactics.svg","effects":[],"_id":"MntKB0rFGM9tiiLx","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945066297,"modifiedTime":1677945067473,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Piloting","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"The individual has training and experience in the operation of interplanetary and interstellar spacecraft. Piloting expertise is necessary to handle such craft, though a check is usually only made when circumstances become challenging, such as due to rough atmospheric conditions or hostile action.","shortdescr":"The individual has training and experience in the operation of interplanetary and interstellar spacecraft.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Piloting","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/piloting.svg","effects":[],"_id":"LOaDL2eSxln7qMXK","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945076072,"modifiedTime":1677945077073,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Navigation","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"The character is trained in the science of normal and Jump space navigation. The Navigator on a starship plots the course and ensures that the astrogational information required by the pilot and other crewmembers is available when it is needed. This skill includes the ability to determine a ship's new location after a Jump ends, plotting a standard course through normal space, and plotting a Jump route through Jump space. A starship cannot make a Jump safely without a Jump route.","shortdescr":"The character is trained in the science of normal and Jump space navigation.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Navigation","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/navigation.svg","effects":[],"_id":"1auGkQ3CqErW2Kn8","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945078593,"modifiedTime":1677945079507,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Melee Combat (Piercing Weapons)","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":1,"characteristic":"STR","type":"skills","description":"The character is skilled at using piercing and thrusting weapons, such as spears and polearms, in personal combat.","shortdescr":"The character is skilled at using piercing and thrusting weapons, such as spears and polearms, in personal combat.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Melee Combat (Piercing Weapons)","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/melee-combat-piercing-weapons.svg","effects":[],"_id":"nozwUFY7SBOaHHIO","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945102473,"modifiedTime":1677945103810,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"name":"Gun Combat (Energy Pistol)","ownership":{"default":0,"KrOiJLcZ94d4ZOL3":3,"H829Kq6g80UJ9CuX":3},"type":"skills","system":{"docReference":"","pdfReference":{"type":"","href":"","label":""},"value":0,"characteristic":"STR","type":"skills","description":"The character is skilled at using advanced pistol-style energy weapons like laser pistols and stunners.","shortdescr":"The character is skilled at using advanced pistol-style energy weapons like laser pistols and stunners.","subtype":"","key":"key","difficulty":"Average","rolltype":"Normal","trainingNotes":"","name":"Gun Combat (Energy Pistol)","reference":""},"flags":{"cf":{"id":"temp_ryrod4jywl","path":"Data Entry#/CF_SEP/CE SRD#/CF_SEP/CE SRD Skills","color":"#000000"}},"img":"systems/twodsix/assets/icons/gun-combat-energy-pistol.svg","effects":[],"_id":"PU13o4eMepDra0kw","folder":null,"sort":0,"_stats":{"systemId":"twodsix","systemVersion":"2.22.0","coreVersion":"10.291","createdTime":1677945115338,"modifiedTime":1677945121761,"lastModifiedBy":"H829Kq6g80UJ9CuX"}},{"_id":"eZSBydGmVQLFwH22","name":"Laser Pistol","ownership":{"default":0,"TZxGG8c7kFt1cyHi":3,"H829Kq6g80UJ9CuX":3},"type":"weapon","system":{"name":"Laser Pistol","techLevel":"12","description":"A pistol equivalent of the laser carbine, though still dependent on an external power pack.","shortdescr":"Laser Pistol - ranged","quantity":1,"weight":"1.2","price":"1000","traits":[],"consumables":[],"skillModifier":0,"skill":"","associatedSkillName":"","equipped":"backpack","docReference":"","pdfReference":{"type":"","href":"","label":""},"target":{"value":null,"width":null,"units":"m","type":"none"},"range":0,"damage":"4d6","damageBonus":0,"magazineSize":25,"ammo":25,"useConsumableForAttack":"","magazineCost":100,"type":"weapon","location":"","lawLevel":"2","rangeBand":"pistol","weaponType":"ranged","damageType":"E","rateOfFire":"1","recoil":"false","features":"","armorPiercing":0,"handlingModifiers":""},"flags":{"cf":{"id":"temp_7b2zwn0irpt"}},"img":"systems/twodsix/assets/icons/laser-pistol.svg","effects":[],"folder":null,"sort":0,"_stats":{"systemI