<div class='custom-system-form-field'>
    <label for='activeEffectTitle-{{appId}}'>
        {{localize 'CSB.ComponentProperties.ActiveEffectContainer.TableTitle'}}</label>
    <input type='text' id='activeEffectTitle-{{appId}}' data-key='title' name='title' value='{{title}}' />
</div>

<div class='custom-system-form-group-outer'>
    <b>{{localize 'CSB.ComponentProperties.ActiveEffectContainer.Columns.Active.Title'}}</b>
    <div class='custom-system-form-group'>
        <div class='custom-system-form-field'>
            <label for='activeEffectActiveEnabled-{{appId}}'>{{localize
                    'CSB.ComponentProperties.ActiveEffectContainer.ColumnEnabled'
                }}</label>
            <input id='activeEffectActiveEnabled-{{appId}}' type='checkbox' data-key='activeEnabled' name='activeEnabled' {{checked staticRowLayout.active.enabled}} />
        </div>
        <div class='custom-system-form-field'>
            <label for='activeEffectActiveLabel-{{appId}}'>{{localize
                    'CSB.ComponentProperties.ActiveEffectContainer.ColumnLabel'
                }}</label>
            <input id='activeEffectActiveLabel-{{appId}}' type='text' data-key='activeLabel' name='activeLabel' value='{{staticRowLayout.active.colName}}' />
        </div>
        <div class='custom-system-form-field'>
            <label for='activeEffectActiveAlign-{{appId}}'>{{localize
                    'CSB.ComponentProperties.ActiveEffectContainer.ColumnAlign'
                }}</label>
            <select id='activeEffectActiveAlign-{{appId}}' data-key='activeAlign' name='activeAlign'>
                {{selectOptions ALIGNMENTS selected=staticRowLayout.active.align localize=true}}
            </select>
        </div>
    </div>
    <div class='custom-system-form-group'>
        <div class='custom-system-form-field'>
            <label for='activeEffectActiveSort-{{appId}}'>{{localize
                    'CSB.ComponentProperties.ActiveEffectContainer.ColumnSort'
                }}</label>
            <input id='activeEffectActiveSort-{{appId}}' type='number' data-key='activeSort' name='activeSort' value='{{staticRowLayout.active.sort}}' />
        </div>
    </div>
</div>

