<div class='custom-system-form-group-outer'>
    <b>{{localize 'CSB.ComponentProperties.ActiveEffectContainer.Columns.Count.Title'}}</b>
    {{#if STATUS_COUNTER_ENABLED}}
        <div class='custom-system-form-group'>
            <div class='custom-system-form-field'>
                <label for='activeEffectCountEnabled-{{appId}}'>{{localize
                        'CSB.ComponentProperties.ActiveEffectContainer.ColumnEnabled'
                    }}</label>
                <input id='activeEffectCountEnabled-{{appId}}' type='checkbox' data-key='countEnabled' name='countEnabled' {{checked staticRowLayout.count.enabled}} />
            </div>
            <div class='custom-system-form-field'>
                <label for='activeEffectCountLabel-{{appId}}'>{{localize
                        'CSB.ComponentProperties.ActiveEffectContainer.ColumnLabel'
                    }}</label>
                <input id='activeEffectCountLabel-{{appId}}' type='text' data-key='countLabel' name='countLabel' value='{{staticRowLayout.count.colName}}' />
            </div>
            <div class='custom-system-form-field'>
                <label for='activeEffectCountAlign-{{appId}}'>{{localize
                        'CSB.ComponentProperties.ActiveEffectContainer.ColumnAlign'
                    }}</label>
                <select id='activeEffectCountAlign-{{appId}}' data-key='countAlign' name='countAlign'>
                    {{selectOptions ALIGNMENTS selected=staticRowLayout.count.align localize=true}}
                </select>
            </div>
        </div>
        <div class='custom-system-form-group'>
            <div class='custom-system-form-field'>
                <label for='activeEffectCountSort-{{appId}}'>{{localize
                        'CSB.ComponentProperties.ActiveEffectContainer.ColumnSort'
                    }}</label>
                <input id='activeEffectCountSort-{{appId}}' type='number' data-key='countSort' name='countSort' value='{{staticRowLayout.count.sort}}' />
            </div>
            <div class='custom-system-form-field'>
                <label for='activeEffectCountReadonly-{{appId}}'>{{localize
                        'CSB.ComponentProperties.ActiveEffectContainer.ColumnReadonly'
                    }}</label>
                <input id='activeEffectCountReadonly-{{appId}}' type='checkbox' data-key='countReadonly' name='countReadonly' {{checked staticRowLayout.count.readonly}} />
            </div>
        </div>

    {{else}}
        <div>
            {{{localize
                'CSB.ComponentProperties.ActiveEffectContainer.StatusCounter'
                url='<a href=https://foundryvtt.com/packages/statuscounter>Status Counter</a>'
            }}}
        </div>
    {{/if}}
</div>

